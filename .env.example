EXPO_PUBLIC_AI_PROVIDER=groq
EXPO_PUBLIC_GROQ_API_KEY=
# Prefer 70b for Mind captions (Malayalam + marketing context). 8b is faster but truncates.
EXPO_PUBLIC_GROQ_MODEL=llama-3.3-70b-versatile
# Vision model when caption is thin (reads text in preview images)
EXPO_PUBLIC_GROQ_VISION_MODEL=meta-llama/llama-4-scout-17b-16e-instruct
EXPO_PUBLIC_OLLAMA_BASE_URL=http://localhost:11434/v1
EXPO_PUBLIC_OLLAMA_MODEL=llama3.2

# Mind link previews + content extract (required for Instagram carousels / captions)
# Run locally: npm run mind-extract  →  http://localhost:8787/?url=ENCODED_URL
# GET {EXPO_PUBLIC_CONTENT_EXTRACT_URL}?url=ENCODED_URL
# Response JSON: { title?, description?, image?, text?, transcript? }
EXPO_PUBLIC_CONTENT_EXTRACT_URL=http://localhost:8787/
# Fallback Open Graph scrape when extract URL is unset
EXPO_PUBLIC_LINK_PREVIEW_PROXY=

# Supabase database (cloud sync storage)
EXPO_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=
# Legacy alias also supported:
# EXPO_PUBLIC_SUPABASE_KEY=

# Firebase Google sign-in (required with Supabase for cloud mode)
EXPO_PUBLIC_FIREBASE_API_KEY=
EXPO_PUBLIC_FIREBASE_AUTH_DOMAIN=your-project.firebaseapp.com
EXPO_PUBLIC_FIREBASE_PROJECT_ID=your-project-id
EXPO_PUBLIC_FIREBASE_APP_ID=
# Web OAuth client ID from Firebase Console (also used as webClientId on Android/iOS)
EXPO_PUBLIC_GOOGLE_WEB_CLIENT_ID=
