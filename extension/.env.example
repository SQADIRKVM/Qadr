# Qadr Browser Extension Environment Variables Example
# Copy this file to '.env' inside the extension folder and fill in your keys.

SUPABASE_URL=https://your-supabase-project-id.supabase.co
SUPABASE_KEY=your-supabase-anon-public-key
FIREBASE_API_KEY=your-firebase-api-key

# Live production web workspace URL (uncomment and customize as needed)
WEB_APP_URL=https://qadr-os.vercel.app

# Local development workspace URL (uncomment to swap)
# WEB_APP_URL=http://localhost:8081
